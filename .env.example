# Launch27 (server — never expose to the browser)
LAUNCH27_SUBDOMAIN=renzen
LAUNCH27_API_KEY=

# Stripe publishable key for card tokenization (client — pk_live_… from Stripe / L27 Connect)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: Launch27 custom field IDs for book-rengoering (set after creating fields in L27 admin).
# Until set, the form matches L27 fields by name at booking time.
# L27_BOOK_CUSTOM_FIELD_CLEANLINESS=
# L27_BOOK_CUSTOM_FIELD_LAST_CLEANED=

# Flytterengøring Launch27 IDs (lib/flytterengoring.ts — category 4)
# FLYT_L27_STAND_CUSTOM_FIELD_ID=114
# Services by stand: 119, 115, 116, 117, 118
# Pricing params (kvm): 15, 20, 22, 23, 24

# L27 custom fields (lib/bookCleaningL27.ts — IDs are not service IDs)
# L27_BOOK_ENTRY_CUSTOM_FIELD_ID=201   # Hvordan får vi adgang til dit hjem?
# L27_LAST_CLEANED_CUSTOM_FIELD_ID=246 # Hvornår blev der sidst gjort rent? (≠ service 246)

# Resend (server — required for forespørgsel confirmation emails)
RESEND_API_KEY=
# RESEND_FROM_EMAIL=Renzen <forespoergsel@mail.renzen.dk>
# NOTIFY_EMAIL=info@renzen.dk

# Signed token for Airbnb inquiry → book flow (server-only, required in production)
# Generate with: openssl rand -base64 32
AIRBNB_INQUIRY_TOKEN_SECRET=

# Optional public site origin for book links in emails (defaults to https://renzen.dk)
# NEXT_PUBLIC_SITE_ORIGIN=https://renzen.dk

# Book-rengoering Launch27 service (Almindelig rengøring / Boligens størrelse)
# L27_BOOK_SERVICE_ID=246
# L27_BOOK_PRICING_PARAM_ID=119

# Rengøringsstand extras on the book-rengoering service (hardcoded in lib/bookCleaningL27.ts)
# L27_EXTRA_MEGET_BESKIDT_ID=250
# L27_EXTRA_EKSTRA_TID_ID=251
# L27_EXTRA_KLUB_ID=184
